# -----------------------------------------------------------------------
# ChargeWise India — Geo Service environment variables
# Requirement 12 AC-4: document every required and optional variable.
# -----------------------------------------------------------------------

# REQUIRED ---------------------------------------------------------------

# Filesystem path to the directory containing GeoJSON datasets.
# The service exits with a non-zero code if this is absent or empty.
DATA_DIR=/data/geojson

# EPSG code for the projected CRS used for all spatial operations.
# Must be an integer. Requirement 3 AC-2 mandates EPSG:32643 (UTM Zone 43N)
# for Indian cities.
DEFAULT_CRS_EPSG=32643

# OPTIONAL ---------------------------------------------------------------

# Log verbosity. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Defaults to INFO when not set.
LOG_LEVEL=INFO

# Comma-separated list of city directory names (lowercase) whose GeoJSON
# datasets are loaded into memory at startup before the service accepts
# traffic.  This moves the cold-load penalty (~44 s per city, dominated by
# population_grid.geojson at 195 k rows) to deploy/startup time rather than
# the first HTTP request, satisfying Requirement 4 AC-2 (response ≤ 10 s).
#
# The service's readiness probe (GET /ready) returns HTTP 503 until every
# city in this list has finished loading, preventing orchestrators from
# routing traffic to a still-warming instance.  GET /health (liveness) is
# unaffected and returns 200 immediately.
#
# Add cities here if you deploy with multiple cities enabled.  Each city
# adds ~44 s to container startup time; plan your readinessProbe
# initialDelaySeconds / failureThreshold accordingly.
#
# Default: bengaluru (single-city MVP)
WARM_CITIES=bengaluru

# Uvicorn bind host and port (used when running directly, not via Docker).
HOST=0.0.0.0
PORT=8001
