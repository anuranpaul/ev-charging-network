# Required build-time variables (Vite exposes these as import.meta.env.*)

VITE_API_URL=http://localhost:8080

# Dark basemap style — required so score-coloured candidate markers stay the
# visual focus. The CARTO Dark Matter GL style is free to use without an API
# key for reasonable traffic. Swap for any MapLibre-compatible style JSON URL.
#
# Good free dark alternatives:
#   CARTO Dark Matter (default, no key):
#     https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
#   Stadia Alidade Smooth Dark (no key for low traffic):
#     https://tiles.stadiamaps.com/styles/alidade_smooth_dark.json
#   MapTiler Dark (requires free API key):
#     https://api.maptiler.com/maps/dataviz-dark/style.json?key=YOUR_KEY
#
VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
